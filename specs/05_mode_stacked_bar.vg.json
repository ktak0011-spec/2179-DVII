{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Horizontal small-multiple donut charts showing public transport mode share by area type, with counts and percentages below each donut.",
  "background": "transparent",
  "data": {"url": "data/mode_summary.csv"},
  "transform": [
    {
      "joinaggregate": [{"op": "sum", "field": "stops", "as": "area_total_stops"}],
      "groupby": ["area_band"]
    },
    {
      "calculate": "datum.stops / datum.area_total_stops",
      "as": "mode_share"
    },
    {
      "calculate": "datum.mode + ': ' + format(datum.stops, ',.0f') + ' stops (' + format(datum.mode_share, '.0%') + ')'",
      "as": "mode_label"
    }
  ],
  "facet": {
    "column": {
      "field": "area_band",
      "type": "nominal",
      "title": null,
      "sort": ["Inner Melbourne", "Middle ring", "Outer / growth corridor"],
      "header": {
        "labelAngle": 0,
        "labelAlign": "center",
        "labelAnchor": "middle",
        "labelColor": "#293233",
        "labelFontSize": 12,
        "labelFontWeight": 800,
        "labelPadding": 8
      }
    }
  },
  "spec": {
    "vconcat": [
      {
        "width": 180,
        "height": 118,
        "mark": {"type": "arc", "innerRadius": 34, "outerRadius": 55, "stroke": "#ffffff", "strokeWidth": 1.2},
        "encoding": {
          "theta": {"field": "stops", "type": "quantitative", "stack": true},
          "color": {
            "field": "mode",
            "type": "nominal",
            "title": "Mode",
            "scale": {
              "domain": ["Train", "Tram", "Bus/coach"],
              "range": ["#5f8fb8", "#bf554b", "#1d6f5a"]
            },
            "legend": null
          },
          "tooltip": [
            {"field": "area_band", "title": "Area type"},
            {"field": "mode", "title": "Mode"},
            {"field": "stops", "title": "Stops", "format": ",.0f"},
            {"field": "mode_share", "title": "Share of stops", "format": ".1%"},
            {"field": "stops_per_10000_people", "title": "Stops per 10,000", "format": ".2f"}
          ]
        }
      },
      {
        "width": 180,
        "height": 66,
        "layer": [
          {
            "transform": [{"filter": "datum.mode == 'Train'"}],
            "mark": {"type": "text", "align": "left", "baseline": "middle", "fontSize": 11, "fontWeight": 750, "color": "#5f8fb8"},
            "encoding": {
              "x": {"datum": 0, "type": "quantitative", "scale": {"domain": [0, 1]}, "axis": null},
              "y": {
                "field": "mode",
                "type": "nominal",
                "title": null,
                "sort": ["Train", "Tram", "Bus/coach"],
                "axis": null
              },
              "text": {"field": "mode_label"},
              "tooltip": [
                {"field": "area_band", "title": "Area type"},
                {"field": "mode", "title": "Mode"},
                {"field": "stops", "title": "Stops", "format": ",.0f"},
                {"field": "mode_share", "title": "Share of stops", "format": ".1%"}
              ]
            }
          },
          {
            "transform": [{"filter": "datum.mode == 'Tram'"}],
            "mark": {"type": "text", "align": "left", "baseline": "middle", "fontSize": 11, "fontWeight": 750, "color": "#bf554b"},
            "encoding": {
              "x": {"datum": 0, "type": "quantitative", "scale": {"domain": [0, 1]}, "axis": null},
              "y": {
                "field": "mode",
                "type": "nominal",
                "title": null,
                "sort": ["Train", "Tram", "Bus/coach"],
                "axis": null
              },
              "text": {"field": "mode_label"},
              "tooltip": [
                {"field": "area_band", "title": "Area type"},
                {"field": "mode", "title": "Mode"},
                {"field": "stops", "title": "Stops", "format": ",.0f"},
                {"field": "mode_share", "title": "Share of stops", "format": ".1%"}
              ]
            }
          },
          {
            "transform": [{"filter": "datum.mode == 'Bus/coach'"}],
            "mark": {"type": "text", "align": "left", "baseline": "middle", "fontSize": 11, "fontWeight": 750, "color": "#1d6f5a"},
            "encoding": {
              "x": {"datum": 0, "type": "quantitative", "scale": {"domain": [0, 1]}, "axis": null},
              "y": {
                "field": "mode",
                "type": "nominal",
                "title": null,
                "sort": ["Train", "Tram", "Bus/coach"],
                "axis": null
              },
              "text": {"field": "mode_label"},
              "tooltip": [
                {"field": "area_band", "title": "Area type"},
                {"field": "mode", "title": "Mode"},
                {"field": "stops", "title": "Stops", "format": ",.0f"},
                {"field": "mode_share", "title": "Share of stops", "format": ".1%"}
              ]
            }
          }
        ]
      }
    ],
    "spacing": 6
  },
  "spacing": 22,
  "config": {
    "view": {"stroke": null},
    "axis": {"grid": false, "domain": false, "ticks": false, "labels": false, "title": null},
    "legend": {"labelColor": "#293233", "titleColor": "#293233"}
  }
}
